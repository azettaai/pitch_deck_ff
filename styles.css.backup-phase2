    /* Tagline adjustments */
    .tagline {
        font-size: 0.6rem !important;
        margin-top: 16px;
    }
    
    .tagline-primary {
        font-size: clamp(0.7rem, 2vw, 0.9rem) !important;
    }
    
    .tagline-secondary {
        font-size: clamp(0.6rem, 1.5vw, 0.75rem) !important;
    }
    
    .tagline-tertiary {
        font-size: clamp(0.55rem, 1.2vw, 0.65rem) !important;
    }
    
    /* Modal adjustments */
    .modal-content {
        padding: 20px;
        margin: 10px;
        max-height: 95vh;
        max-width: 95vw;
    }
    
    .concept-tooltip {
        width: 280px;
        max-width: 85vw;
    }
    
    /* Title slide specific adjustments */
    .slide.invert .content-wrapper {
        padding: 0;
    }
    
    .slide.invert svg {
        width: 100px !important;
        height: 100px !important;
        margin-bottom: 16px !important;
    }
    
    /* Results slide grid */
    #resultsSlide .content-wrapper > div[style*="grid"] {
        grid-template-columns: 1fr 1fr !important;
        gap: 12px !important;
        margin-top: 12px !important;
    }
    
    /* Prevent any scrolling */
    body {
        overflow: hidden !important;
        position: fixed !important;
        width: 100vw !important;
        height: 100vh !important;
    }
    
    .deck-container {
        overflow: hidden !important;
    }
    
    .slide {
        overflow: hidden !important;
    }
    
    .content-wrapper {
        overflow: hidden !important;
        max-height: calc(100vh - 80px);
    }
}

/* Orientation message styling */
#orientation-message {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: var(--bg);
    border: 2px solid var(--primary);
    padding: 40px;
    z-index: 99999;
    font-family: 'Press Start 2P', monospace;
    font-size: 0.7rem;
    color: var(--primary);
    text-align: center;
    box-shadow: 0 0 40px var(--primary-glow);
    max-width: 90vw;
}

/* Additional mobile portrait prevention */
@media (orientation: portrait) and (max-width: 768px) {
    body {
        overflow: hidden !important;
    }
    
    .deck-container {
        display: none;
    }
}