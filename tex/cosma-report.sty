\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{cosma-report}[2025/12/08 Custom style for Cosma Technical Report]

% Base Packages
\RequirePackage[utf8]{inputenc}
\RequirePackage[margin=1in,headheight=22pt]{geometry}
\RequirePackage{graphicx}
\RequirePackage{amsmath}
\RequirePackage{amssymb}
\RequirePackage{enumitem}
\RequirePackage{fancyhdr}
\RequirePackage{tcolorbox}
\tcbuselibrary{skins}
\RequirePackage{xcolor}
\RequirePackage{tikz}
\usetikzlibrary{shapes.geometric, arrows, positioning, fit, backgrounds, calc, shadows, fadings}

% Modern Fonts
\RequirePackage{mathpazo} 
\RequirePackage[scaled=0.95]{helvet}
\RequirePackage{courier}
\linespread{1.05}

% Professional Color Palette
% Deep Navy for primary branding (Trust, Stability)
\definecolor{cosmaBlue}{RGB}{0, 43, 91} 
% Emerald Teal for growth/success (Growth, Money)
\definecolor{cosmaGreen}{RGB}{0, 107, 84}
% Burnt Orange/Bronze for accents (Energy, but controlled)
\definecolor{cosmaOrange}{RGB}{184, 88, 27}
% Deep Purple for innovation (Creativity)
\definecolor{cosmaPurple}{RGB}{81, 45, 109}
% Cool Gray for structure
\definecolor{cosmaGray}{RGB}{108, 117, 125}
% Dark text
\definecolor{cosmaDark}{RGB}{33, 37, 41}

% Semantic Colors
\colorlet{SectionColor}{cosmaBlue}
\colorlet{LinkColor}{cosmaBlue}

% Typography & Spacing
\RequirePackage{parskip}
\setlength{\parindent}{0pt}
\setlength{\parskip}{1em}

% Headings Styling
\RequirePackage{titlesec}
\titleformat{\section}{\color{SectionColor}\Large\bfseries\sffamily\raggedright\uppercase}{\thesection}{1em}{}
\titleformat{\subsection}{\color{SectionColor}\large\bfseries\sffamily\raggedright}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\color{SectionColor}\normalsize\bfseries\sffamily\raggedright}{\thesubsubsection}{1em}{}

% Semantic Box Environment (Professional Style)
% Usage: \begin{cosmabox}[ColorName]{Title} ... \end{cosmabox}
\newtcolorbox{cosmabox}[2][cosmaBlue]{
  enhanced,
  boxrule=0.5pt,
  colback=white,
  colframe=#1,
  coltitle=white,
  title={#2},
  fonttitle=\bfseries\sffamily,
  attach boxed title to top left={xshift=0cm,yshift=0mm},
  boxed title style={
    sharp corners, 
    size=small, 
    colback=#1, 
    frame hidden
  },
  sharp corners,
  top=3mm,
  bottom=3mm,
  left=3mm,
  right=3mm,
  drop lifted shadow=black!15
}

% Header and Footer
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{1pt}
\renewcommand{\headrule}{%
\hbox to\headwidth{%
  \color{cosmaBlue}\leaders\hrule height \headrulewidth\hfill}}

\rhead{\sffamily\small Azetta.ai Technical Whitepaper}
\lhead{\sffamily\small\textbf{Confidential}}
\rfoot{\sffamily\thepage}

% Hyperlink Styling
\RequirePackage{hyperref}
\hypersetup{
    colorlinks=true,
    linkcolor=LinkColor,
    filecolor=LinkColor,      
    urlcolor=LinkColor,
    citecolor=cosmaGreen,
    pdftitle={Cosma Technical Whitepaper},
    pdfpagemode=FullScreen,
}

% Custom Title Command
\newcommand{\makecosmatitle}{
    \begin{titlepage}
        \centering
        \vspace*{2cm}
        
        {\Huge\sffamily\bfseries\color{cosmaBlue} Cosma \par}
        \vspace{0.5cm}
        {\LARGE\sffamily Omnilingual Semantic Search Platform \par}
        \vspace{1.5cm}
        
        {\Large\sffamily Technical Whitepaper - Investor Edition \par}
        \vspace{2cm}
        
        \textbf{Azetta.ai} \par
        Version 1.0 - \today \par
        
        \vfill
        
        {\small\color{cosmaGray} \textbf{Confidential \& Proprietary} \\ Do not distribute without permission.}
        \vspace*{1cm}
    \end{titlepage}
}
